includes:
    - phar://phpstan.phar/conf/bleedingEdge.neon
    - vendor/spaze/phpstan-disallowed-calls/disallowed-dangerous-calls.neon
    - vendor/spaze/phpstan-disallowed-calls/disallowed-execution-calls.neon
    - vendor/spaze/phpstan-disallowed-calls/disallowed-insecure-calls.neon

parameters:
    tmpDir: .cache/phpstan

    paths:
        - src
        - tests

    level: max

    type_coverage:
        return: 100
        param: 100
        property: 100
        constant: 0
        declare: 100

    type_perfect:
        null_over_false: true
        no_mixed: false
        narrow_param: false
        narrow_return: true

    cognitive_complexity:
        class: 80
        function: 20

    strictRules:
        allRules: true

    editorUrl: 'phpstorm://open?file=%%file%%&line=%%line%%'

    treatPhpDocTypesAsCertain: false

    ignoreErrors:
        -
            identifier: trait.unused
            reportUnmatched: false

        -
            identifier: method.notFound
            path: tests/
            reportUnmatched: false
        -
            identifier: method.internalClass
            path: tests/
            reportUnmatched: false
        -
            identifier: method.nonObject
            path: tests/
            reportUnmatched: false
        -
            identifier: staticMethod.dynamicCall
            path: tests/
            reportUnmatched: false
        -
            identifier: classConstant.internalClass
            path: tests/
            reportUnmatched: false
        # pest-plugin-arch's ArchExpectation interface is marked @internal but
        # the fluent helpers (ignoring, etc.) are the user-facing API.
        -
            identifier: method.internalInterface
            path: tests/Arch/
            reportUnmatched: false
        # JSON-RPC response toArray() returns mixed-keyed; tests assert on
        # nested error fields where the shape is known by inspection.
        -
            identifier: offsetAccess.nonOffsetAccessible
            path: tests/
            reportUnmatched: false
        # Laravel\Mcp\Response::json() is marked @internal but is the
        # canonical Tool return helper.
        -
            identifier: staticMethod.internal
            path: tests/
            reportUnmatched: false
        # X402CallTool replicates parent CallTool's `Container::call([$tool, 'handle'])`
        # — PHPStan strict-rules wants a Closure shape, but the array form is what the
        # parent uses and what laravel/mcp's container autowires. Generator generic
        # variance is similar interop noise.
        -
            identifier: argument.type
            path: src/Server/Methods/X402CallTool.php
            reportUnmatched: false
        -
            identifier: return.type
            path: src/Server/Methods/X402CallTool.php
            reportUnmatched: false
        # Same Generator generic variance as X402CallTool — toJsonRpcStreamedResponse
        # returns Generator<mixed, JsonRpcResponse> not Generator<int, JsonRpcResponse>.
        -
            identifier: return.type
            path: src/Server/Methods/X402ReadResource.php
            reportUnmatched: false
        -
            identifier: return.type
            path: src/Server/Methods/X402GetPrompt.php
            reportUnmatched: false
        # CursorPaginator's $items param is Collection<int, mixed>, the trait's
        # advertisePrices() takes Collection<int, Primitive>, and each list
        # handler passes Collection<int, Tool|Resource|Prompt>. PHP generics
        # are invariant in both directions — the laravel/mcp parent List
        # handlers have the same call shape. Same interop-noise exemption as
        # X402CallTool above.
        -
            identifier: argument.type
            path: src/Server/Concerns/AdvertisesX402Price.php
            reportUnmatched: false
        -
            identifier: argument.type
            paths:
                - src/Server/Methods/X402ListTools.php
                - src/Server/Methods/X402ListResources.php
                - src/Server/Methods/X402ListPrompts.php
            reportUnmatched: false
